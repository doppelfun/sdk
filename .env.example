# Agent identity (required for hub: join block, etc.)
DOPPEL_AGENT_API_KEY=

# Hub and engine
HUB_URL=http://localhost:4000
ENGINE_URL=http://localhost:2567

# Block to join (hub block id).
# Engine needs HUB_JWKS_URL, HUB_ISSUER, and matching block config so JWTs verify.
BLOCK_ID=

# --- LLM providers ---
# Default when LLM_PROVIDER unset: google (GOOGLE_API_KEY).
# openrouter — OPENROUTER_API_KEY required.
# google — Gemini API key
# google-vertex — Vertex (GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION, ADC).

# LLM_PROVIDER=openrouter
# LLM_PROVIDER=google
# LLM_PROVIDER=google-vertex

# When LLM_PROVIDER=openrouter — OpenRouter API key
# OPENROUTER_API_KEY=

# When LLM_PROVIDER=google — Gemini Developer API
# GOOGLE_API_KEY=

# When LLM_PROVIDER=google-vertex — ADC or gcloud auth; enable Vertex AI API
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Chat / build model — OpenRouter id when openrouter; Gemini id when google or google-vertex (default gemini-2.5-flash)
# CHAT_LLM_MODEL=openrouter/auto
CHAT_LLM_MODEL=gemini-3.1-flash-lite-preview
# BUILD_LLM_MODEL=openrouter/auto
BUILD_LLM_MODEL=gemini-3.1-pro-preview

# Optional: skill IDs for claw-config (hub GET /api/agents/me/claw-config). Comma-separated
# SKILL_IDS=doppel,doppel-block-builder

# Owner userId — in-world chat from this user = owner commands
# OWNER_USER_ID=

# Optional: tick interval (ms), wake debounce (ms), max chat context, max owner messages
# TICK_INTERVAL_MS=5000
# WAKE_TICK_DEBOUNCE_MS=150
# MAX_CHAT_CONTEXT=20
# MAX_OWNER_MESSAGES=10

# Owner proximity: within this distance (m) agent only follows instructions.
# OWNER_NEARBY_RADIUS_M=14
# When owner away, LLM tick every N ms so behavior follows SOUL (0 = no autonomous ticks until wake)
# AUTONOMOUS_SOUL_TICK_MS=45000

# Hosted agents: skip balance pre-check + report-usage (no deduction; local dev only).
# hosted is set from hub GET /api/agents/me profile only.
# DISABLE_CREDITS=1

# Extra agent logging: tool arg payloads, chat previews, next-tick delay
# CLAW_VERBOSE=1

# NPC-style idle (default): no LLM until DM/owner — matches NpcDriver. Set to 0 for periodic idle ticks.
# CLAW_NPC_STYLE=0

# Auto refresh hub JWT + HTTP session + WS (default 20m). Set 0 to disable.
# SESSION_REFRESH_INTERVAL_MS=1200000
