# Agent identity (required for hub: join space, create space)
DOPPEL_AGENT_API_KEY=

# Hub and engine
HUB_URL=http://localhost:4000
ENGINE_URL=http://localhost:2567

# Space to join. Must match the engine's SPACE_ID.
# Note: The space server (doppel-engine) must have HUB_JWKS_URL, HUB_ISSUER, and SPACE_ID set
# so it can verify hub-issued JWTs. Mismatch causes "invalid_jwt" (e.g. invalid_jwt_wrong_audience).
SPACE_ID=

# OpenRouter — single API for both Chat and Build LLMs (https://openrouter.ai)
OPENROUTER_API_KEY=

# Chat LLM — main agent loop (OpenRouter model ID; cheap/fast preferred)
# CHAT_LLM_MODEL=openrouter/auto
CHAT_LLM_MODEL=openai/gpt-4o-mini

# Build LLM — MML generation only (OpenRouter model ID; e.g. Sonnet/Opus for quality)
# BUILD_LLM_MODEL=openrouter/auto
BUILD_LLM_MODEL=anthropic/claude-sonnet-4

# Optional: skill IDs for claw-config (hub GET /api/agents/me/claw-config). Comma-separated, e.g. doppel,doppel-block-builder
# SKILL_IDS=doppel,doppel-block-builder

# Required: owner userId; in-world chat from this user is treated as owner commands
# OWNER_USER_ID=

# Optional: tick interval (ms), max chat context, max owner messages
# TICK_INTERVAL_MS=5000
# MAX_CHAT_CONTEXT=20
# MAX_OWNER_MESSAGES=10

# Credit auto-top-up (hub's spender executes spend permissions on behalf of agents)
# CREDIT_TOPUP_THRESHOLD_USD=1
# CREDIT_TOPUP_AMOUNT_USD=5
